r mx-auto\">\r\n//                         <h1 id=\"Contact\" className=\"git-head\">{section5Title}</h1>\r\n//                 </div>\r\n//                 </>\r\n//                 <div className=\"container\">\r\n//             <div className=\"git-cont row\">\r\n//                 <div className=\"col-12 col-sm-6 half\">\r\n//                     <form   action={contact.contactUrl ? contact.contactUrl : \"https://formspree.io\"} method={contact.contactUrl ? \"POST\" : \"GET\"}>\r\n//                         <input type=\"text\" id=\"fname\" name=\"firstname\" placeholder=\"Your name\" required></input>\r\n//                         <input type=\"mail\" id=\"mailid\" name=\"Email\" placeholder=\"Email Address\" required></input>\r\n//                         <input type=\"text\" id=\"sub\" name=\"Subject\" placeholder=\"Subject\" required></input>\r\n//                         <textarea id=\"msg\" name=\"message\" placeholder=\"Message\" required></textarea>\r\n//                         <button className='send' style={{cursor: 'pointer', marginTop:\"0px\", padding:'10px', marginBottom:'50px'}} type=\"submit\">Send Message</button>\r\n//                     </form>\r\n//                 </div>\r\n//                 <div className=\"col-12 col-sm-6 half\">\r\n//                     <p className=\"lead\">\r\n//                         {contact.pitch}        \r\n//                     </p>\r\n                   \r\n//                     <div className='info'><strong>Mobile No:</strong> +91 8373043127</div>\r\n//                     <div className='info'><strong>Mail id:</strong> swarnakarsweta@gmail.com</div>\r\n//                 <div className=\"d-flex justify-content-center align-items-center flex-column\">\r\n//                 <div  className='social'>\r\n//                     {social.linkedin && <a title=\"Visit Linkedin profile\" rel=\"noopener noreferrer\" target=\"_blank\"  href={social.linkedin}><i className=\"fab fa-linkedin\"></i></a>}\r\n//                     {social.facebook && <a title=\"Visit Facebok profile\" rel=\"noopener noreferrer\" target=\"_blank\" href={social.facebook}><i className=\"fab fa-facebook\"></i></a>}\r\n//                     {social.twitter && <a title=\"Visit Twitter profile\" rel=\"noopener noreferrer\" target=\"_blank\" href={social.twitter}><i className=\"fab fa-twitter\"></i></a>}\r\n//                     {social.instagram && <a title=\"Visit Instagram profile\" rel=\"noopener noreferrer\" target=\"_blank\" href={social.instagram}><i className=\"fab fa-instagram\"></i></a>}\r\n//                     {social.github && <a title=\"Visit Github profile\" rel=\"noopener noreferrer\" target=\"_blank\" href={social.github}><i className=\"fab fa-github\"></i></a>}<br/>\r\n//                 </div>\r\n//                 <div>\r\n//                     {social.resume && <a title=\"Download Resume\" target=\"_blank\" href={social.resume} download><i className=\"fas fa-download \" ></i></a>}\r\n//                 </div>\r\n//                 </div>\r\n//                 </div>\r\n//             </div>\r\n//             </div>\r\n//         </div>\r\n//             <p id=\"not-dark\" className=\"Copy\">2022 © Developed by <strong>Sweta Swarnakar</strong> and Designed by <strong>{contact.copyright}</strong>.</p>\r\n//         </div>\r\n//     )\r\n    \r\n// }\r\n\r\n// export default Contact\r\n\r\n\r\n\r\n\r\n\r\n\r\nimport React from \"react\";\r\nimport { contact, section5Title, social } from \"../../profile\";\r\n\r\nconst Contact = () => {\r\n  return (\r\n    <div className=\"parallax\">\r\n      <div data-aos=\"zoom-in-up\" data-aos-once=\"true\" className=\"git-form\">\r\n        <>\r\n          <div className=\"git-head-div text-center mx-auto\">\r\n            <h1 id=\"Contact\" className=\"git-head\">\r\n              {section5Title}\r\n            </h1>\r\n          </div>\r\n        </>\r\n        <div className=\"container\">\r\n          <div className=\"git-cont row\">\r\n            <div className=\"col-12 col-sm-6 half\">\r\n              <form\r\n                action={\r\n                  contact.contactUrl\r\n                    ? contact.contactUrl\r\n                    : \"https://formspree.io\"\r\n                }\r\n                method={contact.contactUrl ? \"POST\" : \"GET\"}\r\n              >\r\n                <input\r\n                  type=\"text\"\r\n                  id=\"fname\"\r\n                  name=\"firstname\"\r\n                  placeholder=\"Your name\"\r\n                  required\r\n                ></input>\r\n                <input\r\n                  type=\"mail\"\r\n                  id=\"mailid\"\r\n                  name=\"Email\"\r\n                  placeholder=\"Email Address\"\r\n                  required\r\n                ></input>\r\n                <input\r\n                  type=\"text\"\r\n                  id=\"sub\"\r\n                  name=\"Subject\"\r\n                  placeholder=\"Subject\"\r\n                  required\r\n                ></input>\r\n                <textarea\r\n                  id=\"msg\"\r\n                  name=\"message\"\r\n                  placeholder=\"Message\"\r\n                  required\r\n                ></textarea>\r\n                <button className=\"but\" style={{ cursor: \"pointer\" }} type=\"submit\">\r\n                  Send Message\r\n                </button>\r\n              </form>\r\n            </div>\r\n            <div className=\"col-12 col-sm-6 half\">\r\n              <p className=\"lead\">{contact.pitch}</p>\r\n              \r\n              <div className=\"d-flex justify-content-center align-items-center flex-column\">\r\n                <div className=\"inline-block contactInfo\">\r\n                  {social.Gmail && (\r\n                    <h6\r\n                      className=\".git-cont .fab\"\r\n                      title=\"Visit Facebok profile\"\r\n                      rel=\"noopener noreferrer\"\r\n                      target=\"_blank\"\r\n                      href={social.Gmail}\r\n                    >\r\n                      <i className=\"fab fa fa-envelope\"></i>\r\n                      Swarnakarsweta@gmail.com\r\n                    </h6>\r\n                  )}\r\n                  {social.phone && (\r\n                    <h6\r\n                      className=\".git-cont .fab\"\r\n                      title=\"Visit Facebok profile\"\r\n                      rel=\"noopener noreferrer\"\r\n                      target=\"_blank\"\r\n                      href={social.phone}\r\n                    >\r\n                      <i className=\"fab fa fa-phone\"></i>+91 8373043127\r\n                    </h6>\r\n                  )}\r\n                  {social.linkedin && (\r\n                    <h6\r\n                      title=\"Visit Linkedin profile\"\r\n                      rel=\"noopener noreferrer\"\r\n                    >\r\n                      <a href={social.linkedin} target=\"_blank\">\r\n                        <i className=\"fab fa-linkedin\"></i>\r\n                      </a>\r\n                      Sweta Swarnakar\r\n                    </h6>\r\n                  )}\r\n\r\n                  {social.facebook && (\r\n                    <h6\r\n                      title=\"Visit Instagram profile\"\r\n                      rel=\"noopener noreferrer\"\r\n                    >\r\n                      <a href={social.instagram} target=\"_blank\">\r\n                        <i className=\"fab fa-facebook\"></i>\r\n                      </a>\r\n                      Sweta Swarnakar\r\n                    </h6>\r\n                  )}\r\n                  {social.github && (\r\n                    <h6 title=\"Visit Github profile\" rel=\"noopener noreferrer\">\r\n                      <a href={social.github} target=\"_blank\">\r\n                        <i className=\"fab fa-github\"></i>\r\n                      </a>\r\n                      Sweta Swarnakar\r\n                    </h6>\r\n                  )}\r\n                  {social.resume && (\r\n                    <a title=\"Download Resume\" href={social.resume} download>\r\n                      <i className=\"fas fa-download\"></i>\r\n                    </a>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <p id=\"not-dark\" className=\"Copy\">\r\n        2022 © Copyright <strong>Sweta Swarnakar</strong>. All Rights\r\n        Reserved\r\n      </p>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Contact;\r\n\r\n","C:\\Users\\Asus\\Desktop\\portfoli01\\src\\components\\section\\Header.js",["56"],"import React from 'react';\r\nimport HeaderButton from '../layouts/HeaderButton'\r\nimport { header } from '../../profile'\r\nimport { social } from '../../profile';\r\n\r\n\r\n\r\nconst Header = () => {\r\n\r\n    const scrollTo = () => {\r\n        window.scrollTo({\r\n            top: 100000,\r\n            left: 0,\r\n            behavior: \"smooth\"\r\n        })\r\n    }\r\n\r\n    const toggleDarkMode = (e) =>  {\r\n        document.documentElement.classList.toggle('dark-mode')\r\n        document.getElementById('not-dark').classList.toggle('inverse-dark')\r\n        document.getElementById('not-dark2').classList.toggle('inverse-dark')\r\n        var x = document.getElementsByClassName('img-pro')\r\n        for(let i = 0; i < x.length; i += 1) {\r\n            x.item(i).classList.toggle(\"inverse-dark\");\r\n        }\r\n        \r\n        if (document.documentElement.classList.contains('dark-mode'))\r\n          localStorage.setItem('mode', 'Dark')\r\n        else\r\n          localStorage.setItem('mode', 'Light')\r\n        }\r\n\r\n    return (\r\n        <div>\r\n             \r\n            <div className=\"Header\">\r\n                <h1>{ `I'm ${header.name}` }</h1>\r\n            <p className=\"line-1 anim-typewriter\">welcome to my portfolio.... </p>\r\n            \r\n            <label className=\"switch\">\r\n           \r\n            {/* <div>\r\n                    {social.resume && <a title=\"Download Resume\" target=\"_blank\" href={social.resume} download><button className='res'>Resume</button></a>}\r\n            </div> */}\r\n                <input id=\"mode-switch\" onClick={e => toggleDarkMode(e)} type=\"checkbox\"/>\r\n                <span className=\"slider round\"></span>\r\n            </label>\r\n            \r\n            \r\n            <HeaderButton/>\r\n\r\n            \r\n            </div>\r\n\r\n            \r\n            <img id=\"not-dark\" onClick={scrollTo} alt=\"Contact Me\" title=\"Contact Me\" className=\"gtp\" src=\"doll.png\"></img>\r\n           \r\n        </div>\r\n\r\n    )\r\n    \r\n}\r\n\r\nexport default Header;","C:\\Users\\Asus\\Desktop\\portfoli01\\src\\components\\section\\Works.js",[],"C:\\Users\\Asus\\Desktop\\portfoli01\\src\\components\\layouts\\HeaderButton.js",["57"],"import React from 'react'\r\nimport {social } from '../../profile'\r\n\r\n\r\n\r\nconst HeaderButton = () => {\r\n\r\n    return (\r\n        <>\r\n            \r\n            <div className=\"mx-auto\">\r\n                <a href=\"#about\"><button className=\"see\">Checkout Portfolio<i className=\"fas fa-eye\"></i></button></a>\r\n                <span>\r\n               \r\n                </span>\r\n            </div>\r\n\r\n        </>\r\n    )\r\n}\r\n\r\nexport default HeaderButton\r\n","C:\\Users\\Asus\\Desktop\\portfoli01\\src\\components\\layouts\\Skills.js",[],"C:\\Users\\Asus\\Desktop\\portfoli01\\src\\components\\layouts\\Project.js",["58","59"],"import React from 'react'\r\n\r\n\r\nconst Project = ({id, name,des, url, skills, link }) => {\r\n    console.log(id,name, url);\r\n    return (\r\n        <div data-aos=\"fade-up\" className=\" col-12 col-lg-4 project-card\">\r\n            <div className=\"image-project\">\r\n                <div className={`img-pro ${id}`}></div>\r\n            </div>\r\n            <a title={url} className=\"project-name\" rel=\"noopener noreferrer\" target=\"_blank\" href={url}><h2>{name}</h2></a>\r\n            <h3><b>Description:</b> {des}</h3>\r\n            { skills && <h3><b>Tech Stacks:</b> {skills}</h3>}\r\n            \r\n            <div id='buttons'>\r\n            <div>{url && <a href={url} target=\"_blank\"><i class=\"fas fa-external-link-alt fa-lg\"></i></a>}</div>\r\n            <div>{link && <a href={link} target=\"_blank\"><i className=\"fab fa-github fa-lg\"></i></a>}</div>\r\n            \r\n             </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Project\r\n",{"ruleId":"60","replacedBy":"61"},{"ruleId":"62","replacedBy":"63"},{"ruleId":"64","severity":1,"message":"65","line":151,"column":23,"nodeType":"66","messageId":"67","endLine":151,"endColumn":65,"fix":"68"},{"ruleId":"64","severity":1,"message":"65","line":163,"column":23,"nodeType":"66","messageId":"67","endLine":163,"endColumn":66,"fix":"69"},{"ruleId":"64","severity":1,"message":"65","line":171,"column":23,"nodeType":"66","messageId":"67","endLine":171,"endColumn":63,"fix":"70"},{"ruleId":"71","severity":1,"message":"72","line":4,"column":10,"nodeType":"73","messageId":"74","endLine":4,"endColumn":16},{"ruleId":"71","severity":1,"message":"72","line":2,"column":9,"nodeType":"73","messageId":"74","endLine":2,"endColumn":15},{"ruleId":"64","severity":1,"message":"65","line":16,"column":26,"nodeType":"66","messageId":"67","endLine":16,"endColumn":56,"fix":"75"},{"ruleId":"64","severity":1,"message":"65","line":17,"column":27,"nodeType":"66","messageId":"67","endLine":17,"endColumn":58,"fix":"76"},"no-native-reassign",["77"],"no-negated-in-lhs",["78"],"react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXOpeningElement","noTargetBlank",{"range":"79","text":"80"},{"range":"81","text":"80"},{"range":"82","text":"80"},"no-unused-vars","'social' is defined but never used.","Identifier","unusedVar",{"range":"83","text":"80"},{"range":"84","text":"80"},"no-global-assign","no-unsafe-negation",[6899,6899]," rel=\"noreferrer\"",[7338,7338],[7699,7699],[672,672],[788,788]]